# DDP-API Environment Variables
# Copy this file to .env and fill in your values

# Bearer token for full write access to this middleware
API_BEARER_TOKEN=your-bearer-token

# Bearer token for read-only access (optional — omit to disable read-only key)
# Accepted on query/read endpoints; rejected on any endpoint that mutates data.
API_READ_ONLY_TOKEN=your-read-only-token

# AWS Secrets Manager settings (for production)
# The secret should contain JSON with organizations array and zapier_webhook_url
AWS_SECRET_NAME=ddp-api/org-credentials
AWS_REGION=us-east-1

# Local config path (for development - falls back if Secrets Manager unavailable)
# Copy config.local.example.json to config.local.json and fill in credentials
LOCAL_CONFIG_PATH=config.local.json

# API key store — dedicated secret, decoupled from org-credentials so key
# issuance/revocation never clobbers (or depends on) the Voatz org blob.
# Holds a single top-level `api_keys` array. The EC2 role needs
# secretsmanager:GetSecretValue + PutSecretValue on this secret's ARN.
API_KEYS_SECRET_NAME=ddp-api/api-keys
# Local dev fallback for the key store (copy api-keys.local.example.json)
API_KEYS_LOCAL_PATH=api-keys.local.json

# Voatz API configuration
VOATZ_API_BASE_URL=https://api.voatz.com
VOATZ_API_ORIGIN=https://api.voatz.com

# VoteBot proxy configuration
VOTEBOT_SERVICE_URL=http://localhost:8000
VOTEBOT_WS_URL=ws://localhost:8000/ws/chat
VOTEBOT_API_KEY=your-votebot-api-key

# DDP-Sync proxy configuration
DDP_SYNC_SERVICE_URL=http://localhost:8001
DDP_SYNC_API_KEY=your-ddp-sync-api-key

# OpenStates local api-v3 proxy (Mac Studio via WireGuard)
OPENSTATES_SERVICE_URL=http://10.0.0.8:8002

# Webflow CMS configuration
WEBFLOW_API_TOKEN=your-webflow-api-token
WEBFLOW_COLLECTION_ID=your-bills-collection-id
WEBFLOW_ORGS_COLLECTION_ID=your-orgs-collection-id
